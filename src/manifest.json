{
  "manifest_version": 3,
  "name": "Twitch Bookmark",
  "version": "1.0.0",
  "description": "Twitchの配信やVODの再生位置を簡単かつ安全にブックマークする拡張機能です。",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.twitch.tv/*"
      ],
      "js": [
        "content/index.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/index.html"
  },
  "commands": {
    "bookmark-trigger": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "現在の再生位置をブックマークに保存"
    }
  }
}
